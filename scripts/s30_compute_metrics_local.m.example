% Example local override file for scripts/s30_compute_metrics.m
%
% Usage:
%   1. Copy this file to:
%        scripts/s30_compute_metrics_local.m
%   2. Edit only the values you want to change.
%   3. Do not commit the copied local file.

runID = "R0009";

% Provisional threshold for phi_lv(t)
opts.low_speed_threshold_m_s = 0.02;

% Progress log interval for long runs
opts.log_every = 500;

% Gaussian pre-smoothing sigma [grid cells] for I_circ.
% 0 = no smoothing (default). Fix after pilot analysis.
% opts.smooth_sigma_circ = 0;

% Gaussian pre-smoothing sigma [grid cells] for surface-divergence D_rms.
% Smoothing is essential for divergence; default 1.5.
% opts.smooth_sigma_div = 1.5;
