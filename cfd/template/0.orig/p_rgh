FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      p_rgh;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// p_rgh = p - rho*(g.x) : 静水圧を差し引いた修正圧力 [Pa]

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    inletOutlet
    {
        // 面を通る流束が U 側の条件と整合するよう圧力勾配を決める。
        type            fixedFluxPressure;
        value           uniform 0;
    }

    atmosphere
    {
        // 大気圧基準の全圧固定(p_rgh 形式)。
        type            prghTotalPressure;
        p0              uniform 0;
        value           uniform 0;
    }

    walls
    {
        type            fixedFluxPressure;
        value           uniform 0;
    }
}

