#!/bin/sh
#------------------------------------------------------------------------------
# 計算結果を消して、配布時の状態に戻す。設定ファイルとメッシュは残す。
#------------------------------------------------------------------------------
cd "$(dirname "$0")" || exit 1

rm -rf 0 processor* postProcessing log.*

# 時刻ディレクトリ(0.5 や 12.5 など数字で始まるもの)を消す
for d in [0-9]*; do
    [ -d "$d" ] && [ "$d" != "0.orig" ] && rm -rf "$d"
done

echo "cleaned."
