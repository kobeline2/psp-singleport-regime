% Example local override file for scripts/s10_prepare_frames.m
%
% Usage:
%   1. Copy this file to:
%        local/settings/s10_prepare_frames_local.m
%   2. Edit only the values you want to change.
%   3. Do not commit the copied local file.

% Target run ID from metadata/runs.csv
runID = "R0009";

% Rectification settings
do_select_rectification = false;
rectification_frame_idx = 1;

% Temporary PIVLab sequence settings
make_pivlab_tmp = true;
pivlab_variant = "long";

% Main rectified TIFF export
opts.start_frame = 1;
opts.end_frame = Inf;
opts.frame_step = 6;

% Temporary PIVLab-ready sequence
pivlab_opts.frame_start = 1;
pivlab_opts.frame_end = Inf;
pivlab_opts.frame_step = 5;
pivlab_opts.start_index = 1000;
