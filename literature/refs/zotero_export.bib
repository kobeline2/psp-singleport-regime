@article{camnasioPredictionMeanTurbulent2014,
  title = {Prediction of {{Mean}} and {{Turbulent Kinetic Energy In Rectangular Shallow Reservoirs}}},
  author = {Camnasio, Erica and Erpicum, Sebastien and Archambeau, Pierre and Pirotton, Michel and Dewals, Benjamin},
  year = 2014,
