  langid = {english},
  file = {/Users/takahiro/Zotero/storage/EHD2XR4F/Dewals et al. - 2008 - Experimental and numerical analysis of flow instab.pdf}
}

@article{dewalsWhatDoesVolumeaveraged2024,
