}

@article{dufresneExperimentalInvestigationFlow2010,
  title = {Experimental Investigation of Flow Pattern and Sediment Deposition in Rectangular Shallow Reservoirs},
  author = {Dufresne, Matthieu and Dewals, Benjamin J. and Erpicum, S{\'e}bastien and Archambeau, Pierre and Pirotton, Michel},
  year = 2010,
