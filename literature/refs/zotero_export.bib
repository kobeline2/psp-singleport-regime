@article{babarutsiDyeConcentrationDistributionShallow1991,
  title = {Dye-{{Concentration Distribution}} in {{Shallow Recirculating Flows}}},
  author = {Babarutsi, S. and Chu, V. H.},
  year = 1991,
  month = may,
  journal = {Journal of Hydraulic Engineering},
  volume = {117},
  number = {5},
  pages = {643--659},
  issn = {0733-9429, 1943-7900},
  doi = {10.1061/(ASCE)0733-9429(1991)117:5(643)},
  urldate = {2026-06-18},
  abstract = {Dye-concentration measurements are conducted in the recirculating region of a sudden open-channel-flow expansion, where the water depth is shallow compared with the horizontal length scale of the channel expansion. The turbulent motion is anisotropic, and is subjected to a stabilizing bed-friction influence, in the confinement between the free surface and the channel bed. Two opposing mechanisms affect the transverse mixing processes in the shallow recirculating flow. On the one hand, the transverse mixing is reduced by the stabilizing bed-friction effect. On the other hand, it is enhanced by a confinement effect, which becomes effective when the width-to-depth ratio of the channel expansion exceeds a value of about 9 \textasciitilde{} 12. These opposing influences are equally significant in the range of the bed-friction number from 0.08-0.10. The concentration data of the present investigation are complementary to the published velocity data obtained in the same recirculating flows. Both sets of data are useful for model calibration of shallow open-channel flows.},
  langid = {english},
  file = {/Users/takahiro/Zotero/storage/2C7MHE6L/Babarutsi and Chu - 1991 - Dye‐Concentration Distribution in Shallow Recirculating Flows.pdf}
}

@article{babarutsiExperimentalInvestigationShallow1989,
  title = {Experimental {{Investigation}} of {{Shallow Recirculating Flows}}},
  author = {Babarutsi, S. and Ganoulis, J. and Chu, V. H.},
  year = 1989,
  month = jul,
  journal = {Journal of Hydraulic Engineering},
  volume = {115},
  number = {7},
  pages = {906--924},
  issn = {0733-9429, 1943-7900},
  doi = {10.1061/(ASCE)0733-9429(1989)115:7(906)},
  urldate = {2026-06-18},
  abstract = {Experiments were conducted to study the bed-friction influence in the recirculating zone of a shallow open-channel flow. Velocity measurements were made using a hot-film anemometer. The recirculating flow rate and the length of the recirculating zone were determined from the measurements, and they are related to a horizontal length scale and a bed-friction length scale. For deep flows, the results are independent of the bed-friction length scale. For shallow flows, the results are independent of the horizontal length scale. Turbulence in the recirculating flows is generated, on one hand, by the bed friction and, on the other hand, by the transverse shear. The bed-generated component is proportional to the bedfriction velocity. The transverse component is confined to a transverse, mixing region. In the limit of shallow water depth, when the flow is under strong bedfriction influence, both the transverse mixing region and the recirculating zone have the same length of about one friction length scale.},
  langid = {english},
  file = {/Users/takahiro/Zotero/storage/AYQMY7RL/Babarutsi et al. - 1989 - Experimental Investigation of Shallow Recirculating Flows.pdf}
}

@article{baiMultiscaleTurbulenceCharacteristics2026,
  title = {Multi-Scale Turbulence Characteristics and Energy Transfer Analysis of Lateral Inlet/Outlets Based on {{POD}}/{{DMD}}},
  author = {Bai, Boyuan and Zhu, Hongtao and Gao, Xueping and Liu, Yinzhu},
  year = 2026,
  month = jul,
  journal = {Energy},
  volume = {355},
  pages = {141236},
  issn = {03605442},
  doi = {10.1016/j.energy.2026.141236},
  urldate = {2026-07-17},
  abstract = {Local head losses in lateral inlet/outlets of pumped storage power stations account for 6.7--8.3\% of total system losses, yet the underlying multi-scale turbulent mechanisms remain poorly understood. Prior work focused on time-averaged and single-scale flow features, leaving cross-scale energy transfer pathways unexplored. This study employs Large Eddy Simulation (Re = 2.5 \texttimes{} 107, 42-million-cell mesh, 35 flow-through periods) combined with Proper Orthogonal Decomposition (POD) and Dynamic Mode Decomposition (DMD) to characterize multiscale turbulence and quantify energy cascade mechanism in lateral inlet/outlets. Results show geometric expansion creates a middle transition zone (x/D = 2.0--5.0) where turbulent kinetic energy (TKE) production peaks at 12 times the entrance baseline, identifying it as the primary site of hydraulic loss. POD identifies hierarchically distributed coherent structures, with the leading five modes capturing over 70\% of total TKE: the dominant mode (0.09 Hz) governs large-scale low-frequency separation oscillations, intermediate modes exhibit dual-peak spectra reflecting cross-scale coupling, and higher-order modes represent small-scale dissipation. DMD reveals a clear spectral bifurcation between large-scale low-frequency and small-scale high-frequency modes. Critically, the framework uncovers a dual-pathway energy transfer mechanism departing from the classical Kolmogorov cascade: 43\% \textpm{} 0.73\% of large-scale energy bypasses the sequential cascade via non-local energy transfer into intermediate scales, while 65\% \textpm{} 1.02\% of high-frequency energy originates from coupling with low-frequency structures (phase synchronization Index = 0.78 \textpm{} 0.02). These findings demonstrate that suppressing low-frequency global instabilities, rather than solely targeting small-scale turbulence, is key to optimizing hydraulic performance and provides a theoretical basis for flow control in lateral inlet/outlets.},
  langid = {english},
  file = {/Users/takahiro/Zotero/storage/FR457UYH/Bai et al. - 2026 - Multi-scale turbulence characteristics and energy transfer analysis of lateral inletoutlets based o.pdf}
}

