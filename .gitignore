# ============================================================
#  Mac + Python + MATLAB + Dropbox 併用環境 最適化 .gitignore
# ============================================================

# ---------------------------------------
# 1) Dropbox リンク（共有データ）
# ---------------------------------------
# Dropbox 側に置いたデータ置き場（シンボリックリンク）
# GitHub にデータを絶対に入れないため必須
raw/
derived/
piv_exports/
results/
config/project_config_local.m
memo.txt

# ---------------------------------------
# 1a) リポジトリ内 local/ データルート
# ---------------------------------------
# 説明用 README と空ディレクトリ用 .gitkeep だけ残し、
# 実データ本体は Git 管理しない
/local/raw/**
!/local/raw/
!/local/raw/R0001/
!/local/raw/.gitkeep
!/local/raw/R0001/.gitkeep

/local/work/**
!/local/work/
!/local/work/R0001/
!/local/work/R0001/rectified_tif/
!/local/work/R0001/pivlab_proj/
!/local/work/exports/
!/local/work/.gitkeep
!/local/work/R0001/.gitkeep
!/local/work/R0001/rectified_tif/.gitkeep
!/local/work/R0001/pivlab_proj/.gitkeep
!/local/work/exports/.gitkeep

/local/derived/**
!/local/derived/
!/local/derived/piv/
!/local/derived/metrics/
!/local/derived/qc/
!/local/derived/.gitkeep
!/local/derived/piv/.gitkeep
!/local/derived/metrics/.gitkeep
!/local/derived/qc/.gitkeep

/local/results/**
!/local/results/
!/local/results/figures/
!/local/results/tables/
!/local/results/drafts/
!/local/results/.gitkeep
!/local/results/figures/.gitkeep
!/local/results/tables/.gitkeep
!/local/results/drafts/.gitkeep

/local/settings/**
!/local/settings/
!/local/settings/.gitkeep
!/local/settings/README.md
!/local/settings/s10_prepare_frames_local.m.example

!/local/README.md

# ---------------------------------------
# 2) Python バイトコード / キャッシュ
# ---------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
venv/
.env/
*.egg-info/
.eggs/

# Jupyter notebooks cache
.ipynb_checkpoints/
.jupyter/

# ---------------------------------------
# 3) MATLAB 特有のゴミ / 中間生成物
# ---------------------------------------
*.mat
*.m~
*.asv       # autosave files
*.mex*      # compiled MEX files
slprj/      # Simulink build
sccprj/
codegen/

# MATLAB の補助ファイル
*.mlx.autosave
*.bak
*.log

# ---------------------------------------
# 4) 大容量データ（研究用中間生成物を誤コミットしない）
# ---------------------------------------
# *.csv
*.h5
*.hdf5
*.nc
*.bin
*.dat
*.tif
*.tiff
*.jpg
*.png
*.mp4
*.mov

# ---------------------------------------
# 5) Mac 特有のゴミ
# ---------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# macOS が勝手に作るアイコンファイル（Icon\r → 文字化け対策）
Icon?
.icon?
._*

# ---------------------------------------
# 6) システム/エディタごとのファイル
# ---------------------------------------
# VSCode
.vscode/

# PyCharm / JetBrains
.idea/

# Backup files
*~

# ---------------------------------------
# 7) その他 sandbox / 作業用ディレクトリ
# ---------------------------------------
tmp/
temp/
scratch/
logs/
results/
figures/

# ---------------------------------------
# 8) 自分だけのローカル設定を置く場所
# ---------------------------------------
config_local/
