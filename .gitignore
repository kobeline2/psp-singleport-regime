# ============================================================
#  Mac + Python + MATLAB + Dropbox 併用環境 最適化 .gitignore
# ============================================================

# ---------------------------------------
# 1) Dropbox リンク（共有データ）
# ---------------------------------------
# Dropbox 側に置いたデータ置き場（シンボリックリンク）
# GitHub にデータを絶対に入れないため必須
/raw/
/derived/
/piv_exports/
/results/
config/project_config_local.m
memo.txt

# ---------------------------------------
# ---------------------------------------
# 1a) リポジトリ内 local/ データルート
# ---------------------------------------
# local/ は実データ置き場。中身は全てGit管理外。
# フォルダ構造はスクリプトの mkdir が実行時に自動生成する。
/local/
!/local/README.md


# ---------------------------------------
# 1b) scripts/ 隣接ローカル override
# ---------------------------------------
/scripts/*_local.m
!/scripts/*_local.m.example

# ---------------------------------------
# 2) Python バイトコード / キャッシュ
# ---------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
venv/
.env/
*.egg-info/
.eggs/

# Jupyter notebooks cache
.ipynb_checkpoints/
.jupyter/

# ---------------------------------------
# 3) MATLAB 特有のゴミ / 中間生成物
# ---------------------------------------
*.mat
*.m~
*.asv       # autosave files
*.mex*      # compiled MEX files
slprj/      # Simulink build
sccprj/
codegen/

# MATLAB の補助ファイル
*.mlx.autosave
*.bak
*.log

# ---------------------------------------
# 4) 大容量データ（研究用中間生成物を誤コミットしない）
# ---------------------------------------
# *.csv
*.pdf
*.h5
*.hdf5
*.nc
*.bin
*.dat
*.tif
*.tiff
*.jpg
*.png
*.mp4
*.mov
# paper/ 内の図ファイルは追跡する
!paper/**/*.png
!paper/**/*.pdf

# ---------------------------------------
# 5) Mac 特有のゴミ
# ---------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# macOS が勝手に作るアイコンファイル（Icon\r → 文字化け対策）
Icon?
.icon?
._*

# ---------------------------------------
# 6a) LaTeX 中間生成物
# ---------------------------------------
*.synctex.gz
*.aux
*.out
*.bcf
*.run.xml
*.blg
*.bbl
*.fls
*.fdb_latexmk
*.toc
*.lof
*.lot
*.dvi

# ---------------------------------------
# 6) システム/エディタごとのファイル
# ---------------------------------------
# VSCode
.vscode/
!paper/2026_journal_Shonai/.vscode/
!paper/2026_journal_Shonai/.vscode/settings.json
!literature/.vscode/
!literature/.vscode/settings.json

# PyCharm / JetBrains
.idea/

# Backup files
*~

# ---------------------------------------
# 7) その他 sandbox / 作業用ディレクトリ
# ---------------------------------------
tmp/
temp/
scratch/
logs/
/figures/
paper/**/out/

# ---------------------------------------
# 8) 自分だけのローカル設定を置く場所
# ---------------------------------------
config_local/

# ===== baseline (cleanup) =====
.DS_Store
.dropboxignore
*conflicted copy*
*Conflicted Copy*
untitled*.m
*.asv
matlab_workspace.mat
__pycache__/
*.pyc
.venv/
*.dSYM/
